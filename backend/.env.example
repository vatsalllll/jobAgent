# ── LLM PROVIDER ────────────────────────────────────
# Which LLM to use: anthropic | huggingface | openai
LLM_PROVIDER=huggingface

# Hugging Face (free tier or paid)
# Get your token at https://huggingface.co/settings/tokens
HF_API_KEY=hf_...
# Recommended models for resume tailoring (ranked):
#   Qwen/Qwen3-8B              — best JSON output, 32K context, free tier
#   meta-llama/Llama-3.1-8B-Instruct — good all-rounder, 128K context
#   mistralai/Mistral-7B-Instruct-v0.3 — fast, decent JSON, free tier 
#   deepseek-ai/DeepSeek-V3    — best quality, PAID (excellent structured output)
#   meta-llama/Llama-4-Maverick-17B-128E — cutting-edge, PAID
HF_MODEL=Qwen/Qwen3-8B

# Optional: dedicated endpoint URL (faster, more reliable)
# HF_ENDPOINT_URL=

# Anthropic Claude (backup option)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (backup option)
OPENAI_API_KEY=

# ── RECOMMENDED ────────────────────────────────────
# Hunter.io for finding founder/hiring manager emails
# Get yours at https://hunter.io/api_keys
HUNTER_API_KEY=

# Google Custom Search API (alternative to Hunter.io)
# Create at https://programmablesearchengine.google.com/ (enable "Search entire web")
# Get API key at https://console.cloud.google.com/apis/credentials
GOOGLE_SEARCH_API_KEY=
GOOGLE_CSE_ID=

# Google Sheets tracking — path to OAuth 2.0 client secret JSON
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CREDENTIALS_JSON=data/google_credentials.json

# Google Sheets spreadsheet ID (from the sheet URL)
# https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
TRACKING_SHEET_ID=

# ── OPTIONAL ───────────────────────────────────────
# For multi-model swarm consensus
GEMINI_API_KEY=

# ── EMAIL ──────────────────────────────────────────
SENDER_EMAIL=vatsalomar1@gmail.com
SENDER_NAME=Vatsal Omar

# ── JOB FILTERS ────────────────────────────────────
MIN_SALARY_INR=50000
MAX_LISTING_AGE_DAYS=4

# ── SCHEDULER ──────────────────────────────────────
# How often to run the job sweep (in hours)
SWEEP_INTERVAL_HOURS=4

# ── SERVER ─────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
