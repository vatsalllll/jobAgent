# ── LLM PROVIDER ────────────────────────────────────
# Sets the PRIMARY provider. The rest are used as automatic fallbacks in this order:
#   groq → gemini → openrouter → anthropic → openai → huggingface
# A rate-limit/outage on one transparently falls through to the next.
# Options: groq | gemini | openrouter | anthropic | openai | huggingface
LLM_PROVIDER=groq

# Groq (RECOMMENDED, free) — fast Llama 3.3 70B. Get a key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (free) — fallback. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter (optional) — many free models. https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Hugging Face (free tier) — final fallback. https://huggingface.co/settings/tokens
HF_API_KEY=
HF_MODEL=Qwen/Qwen3-8B
HF_PROVIDER=groq

# Anthropic Claude (optional, paid). https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (optional, paid)
OPENAI_API_KEY=

# ── FREE CONTACT DISCOVERY ─────────────────────────
# Free GitHub Personal Access Token (no scopes needed) raises the GitHub API limit
# from 60 → 5000 req/hr for finding real developer emails. https://github.com/settings/tokens
GITHUB_TOKEN=

# Adzuna (optional, free) — India + salary data. https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ── RECOMMENDED ────────────────────────────────────
# Hunter.io for finding founder/hiring manager emails
# Get yours at https://hunter.io/api_keys
HUNTER_API_KEY=

# Google Custom Search API (alternative to Hunter.io)
# Create at https://programmablesearchengine.google.com/ (enable "Search entire web")
# Get API key at https://console.cloud.google.com/apis/credentials
GOOGLE_SEARCH_API_KEY=
GOOGLE_CSE_ID=

# Google Sheets tracking — path to OAuth 2.0 client secret JSON
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CREDENTIALS_JSON=data/google_credentials.json

# Google Sheets spreadsheet ID (from the sheet URL)
# https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
TRACKING_SHEET_ID=

# ── OPTIONAL ───────────────────────────────────────
# For multi-model swarm consensus
GEMINI_API_KEY=

# ── EMAIL ──────────────────────────────────────────
SENDER_EMAIL=vatsalomar1@gmail.com
SENDER_NAME=Vatsal Omar

# ── API AUTH ───────────────────────────────────────
# Protects the sending/mutating endpoints: /daily-sweep, /sync-sheets, /check-emails,
# /track, /dashboard, /download-pdf. The GitHub Actions scheduler must send this as the
# `x-api-key` header, so ALSO add it as a GitHub repo secret named API_KEY.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# ── JOB FILTERS ────────────────────────────────────
MIN_SALARY_INR=50000
MAX_LISTING_AGE_DAYS=4

# ── SCHEDULER ──────────────────────────────────────
# How often to run the job sweep (in hours)
SWEEP_INTERVAL_HOURS=4

# ── SERVER ─────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
